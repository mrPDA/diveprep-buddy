{
  "name": "diveprep-buddy",
  "version": "0.1.0",
  "description": "Pre-dive preparation PWA: context → checklist → buddy-check → summary. Offline-first, no backend.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://diveprep-buddy.pages.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/mrPDA/diveprep-buddy.git"
  },
  "bugs": {
    "url": "https://github.com/mrPDA/diveprep-buddy/issues"
  },
  "keywords": [
    "pwa",
    "scuba-diving",
    "checklist",
    "offline-first",
    "react",
    "vite",
    "typescript",
    "indexeddb"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:audit": "node scripts/test-audit.mjs",
    "verify": "npm run test && npm run build",
    "preview": "vite preview",
    "content:assemble": "node scripts/content-tools.mjs assemble",
    "content:sync": "node scripts/content-tools.mjs sync",
    "content:apply": "node scripts/content-tools.mjs apply",
    "content:studio": "VITE_CONTENT_STUDIO=true vite"
  },
  "dependencies": {
    "dexie": "^4.4.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.7"
  }
}
